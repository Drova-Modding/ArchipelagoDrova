<Project>
  <PropertyGroup>
    <!-- Path to your Drova install (the folder containing Drova.exe). Defaults to the standard Steam
         location. If yours differs, do NOT edit this file - override it instead, so you never commit a
         local path back:
           - set a GamePath environment variable, or
           - pass -p:GamePath="D:\path\to\Drova - Forsaken Kin" to dotnet build. -->
    <GamePath Condition="'$(GamePath)' == ''">C:\Program Files (x86)\Steam\steamapps\common\Drova - Forsaken Kin</GamePath>
  </PropertyGroup>
</Project>