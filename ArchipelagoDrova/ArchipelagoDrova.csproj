	<!-- Deploy: mod DLL -> Mods/, Archipelago client -> UserLibs/.
	     UserLibs is MelonLoader's dependency folder: every managed DLL there is eagerly loaded,
	     whereas a non-Melon DLL in Mods/ is skipped by the preprocessor.
	     Newtonsoft.Json is deliberately NOT deployed - MelonLoader/net6 already supplies 13.0.4,
	     which wins resolution by filename and satisfies the AP client's v11 reference. -->
	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<MakeDir Directories="$(GamePath)/UserLibs" />
		<Copy SourceFiles="$(TargetPath)" DestinationFolder="$(GamePath)/Mods" />
		<Copy SourceFiles="$(TargetDir)Archipelago.MultiClient.Net.dll" DestinationFolder="$(GamePath)/UserLibs" />
	</Target>

	<!-- ============================================================
	     Release packaging. A Release build produces these assets in <repo>/release/, split by
	     destination - the game and Archipelago are separate programs:

	         ArchipelagoDrova-v<version>.zip              unzip into the Drova ROOT (Vortex-friendly):
	             Mods/      ArchipelagoDrova.dll   (Drova Modding API is a separate install, not bundled)
	             UserLibs/  Archipelago.MultiClient.Net.dll
	             README.md
	         ArchipelagoDrova-Archipelago-v<version>.zip  unzip into the ARCHIPELAGO ROOT:
	             custom_worlds/  drova.apworld
	             Players/        Drova - Forsaken Kin.yaml   (sample config)
	         drova.apworld                                standalone, the conventional bare-apworld
	                                                      drop-in for Archipelago custom_worlds/

	     Each zip mirrors where its files go, so extracting into the matching root places everything
	     correctly (convenient for Vortex/NexusMods and manual installs alike). The apworld and yaml
	     belong in the Archipelago install, not the game, so they are never inside the game zip.

	     Off for Debug so the inner dev loop stays fast. Force it on any config with -p:BundleRelease=true,
	     or off with -p:BundleRelease=false.

	     The .apworld is NOT built here (that needs an Archipelago source checkout - see README "Building
	     the apworld"); this copies the drova.apworld already at the repo root and errors if it is missing,
	     so rebuild it before cutting a release.
	     ============================================================ -->
	<PropertyGroup>
		<RepoRoot>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\..'))</RepoRoot>
		<!-- Keep in sync with apworld/drova/archipelago.json "world_version". -->
		<ReleaseVersion Condition="'$(ReleaseVersion)' == ''">0.2.0</ReleaseVersion>
		<ApWorldFile>$(RepoRoot)\drova.apworld</ApWorldFile>
		<ReleaseStageDir>$(MSBuildProjectDirectory)\obj\release-stage\</ReleaseStageDir>
		<ApStageDir>$(MSBuildProjectDirectory)\obj\release-stage-ap\</ApStageDir>
		<ReleaseOutDir>$(RepoRoot)\release\</ReleaseOutDir>
		<ReleaseZip>$(ReleaseOutDir)ArchipelagoDrova-v$(ReleaseVersion).zip</ReleaseZip>
		<ReleaseApZip>$(ReleaseOutDir)ArchipelagoDrova-Archipelago-v$(ReleaseVersion).zip</ReleaseApZip>
		<!-- The Drova Modding API is a separate project with its own releases and versioning, so it is
		     NOT bundled - users install it themselves (see the README). Set -p:BundleDrovaApi=true only
		     if you deliberately want a self-contained zip. -->
		<BundleDrovaApi Condition="'$(BundleDrovaApi)' == ''">false</BundleDrovaApi>
	</PropertyGroup>

	<!-- Gate on the target condition, not a defaulted property: an end-of-file PropertyGroup that
	     reads $(Configuration) evaluates unreliably, but a target condition is evaluated at run time.
	     NOTE: the flag is BundleRelease, NOT PackRelease - PackRelease is a reserved .NET SDK property
	     that defaults to true, so reusing it would make this run on every config.
	     Runs on Release (unless -p:BundleRelease=false), or on any config with -p:BundleRelease=true. -->
	<Target Name="PackRelease" AfterTargets="Build"
	        Condition="'$(BundleRelease)' == 'true' or ('$(Configuration)' == 'Release' and '$(BundleRelease)' != 'false')">
		<Error Condition="!Exists('$(ApWorldFile)')"
		       Text="drova.apworld not found at $(ApWorldFile). Build it first (README: 'Building the apworld'), then re-run the Release build." />

		<RemoveDir Directories="$(ReleaseStageDir)" />
		<MakeDir Directories="$(ReleaseStageDir)Mods;$(ReleaseStageDir)UserLibs;$(ReleaseOutDir)" />

		<!-- Game files ONLY: this stage is what a mod manager unpacks into the Drova root. -->
		<Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ReleaseStageDir)Mods" />
		<Copy SourceFiles="$(GamePath)\Mods\Drova_Modding_API.dll" DestinationFolder="$(ReleaseStageDir)Mods"
		      Condition="'$(BundleDrovaApi)' == 'true'" />
		<Copy SourceFiles="$(TargetDir)Archipelago.MultiClient.Net.dll" DestinationFolder="$(ReleaseStageDir)UserLibs" />
		<Copy SourceFiles="$(RepoRoot)\README.md" DestinationFolder="$(ReleaseStageDir)" />

		<Delete Files="$(ReleaseZip)" Condition="Exists('$(ReleaseZip)')" />
		<ZipDirectory SourceDirectory="$(ReleaseStageDir)" DestinationFile="$(ReleaseZip)" />

		<!-- Archipelago-side zip: mirrors the Archipelago folder tree, so extracting it into the
		     Archipelago ROOT drops the apworld and yaml into their subfolders in one step (handy for a
		     NexusMods/manual install). These belong in the Archipelago install, not the game, so they
		     are never inside the game zip. -->
		<RemoveDir Directories="$(ApStageDir)" />
		<MakeDir Directories="$(ApStageDir)custom_worlds;$(ApStageDir)Players" />
		<Copy SourceFiles="$(ApWorldFile)" DestinationFolder="$(ApStageDir)custom_worlds" />
		<Copy SourceFiles="$(RepoRoot)\apworld\drova\docs\Drova - Forsaken Kin.yaml" DestinationFolder="$(ApStageDir)Players" />
		<Delete Files="$(ReleaseApZip)" Condition="Exists('$(ReleaseApZip)')" />
		<ZipDirectory SourceDirectory="$(ApStageDir)" DestinationFile="$(ReleaseApZip)" />

		<!-- Also ship the bare apworld: the conventional drop-into-custom_worlds/ format AP users expect. -->
		<Copy SourceFiles="$(ApWorldFile)" DestinationFolder="$(ReleaseOutDir)" />

		<Message Importance="high" Text="Release assets in $(ReleaseOutDir)" />
		<Message Importance="high" Text="  game mod    (unzip into Drova root)       -&gt; $(ReleaseZip)" />
		<Message Importance="high" Text="  archipelago (unzip into Archipelago root) -&gt; $(ReleaseApZip)" />
		<Message Importance="high" Text="  apworld     (standalone, custom_worlds/)  -&gt; $(ReleaseOutDir)drova.apworld" />
	</Target>
</Project>