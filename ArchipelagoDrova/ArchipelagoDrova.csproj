<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net6.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<!-- Nullable MUST stay disabled: under IL2CPP, System.Runtime.CompilerServices.NullableAttribute
		     resolves into Il2Cppmscorlib and breaks the build/runtime. -->
		<Nullable>disable</Nullable>
		<RootNamespace>ArchipelagoDrova</RootNamespace>
		<IsPackable>false</IsPackable>
		<AssemblyVersion>1.0.0.0</AssemblyVersion>
		<FileVersion>1.0.0.0</FileVersion>
		<NeutralLanguage>en-US</NeutralLanguage>
		<AssemblyName>ArchipelagoDrova</AssemblyName>
		<LangVersion>latest</LangVersion>
		<!-- Required for Archipelago.MultiClient.Net to appear in the output at all:
		     it vendors its deps as lib assets rather than package dependencies. -->
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<!-- Silence MSB3270. The mod stays AnyCPU/MSIL on purpose: MelonLoader loads it into the
		     already-x64 game process, so referencing the x64 MelonLoader/Il2Cpp DLLs is not a real
		     architecture conflict. Do NOT "fix" this by forcing PlatformTarget=x64. -->
		<ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>None</ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Archipelago.MultiClient.Net" Version="6.7.1" />
	</ItemGroup>

	<ItemGroup>
		<Reference Include="Drova_Modding_API">
			<HintPath>$(GamePath)/Mods\Drova_Modding_API.dll</HintPath>
			<Private>false</Private>
		</Reference>
		<!-- Bind to MelonLoader's Newtonsoft (13.0.4). It wins resolution over anything we could ship,
		     and CoreCLR satisfies the AP client's v11 reference with it. Never ship our own copy. -->
		<Reference Include="Newtonsoft.Json">
			<HintPath>$(GamePath)/MelonLoader\net6\Newtonsoft.Json.dll</HintPath>
			<Private>false</Private>
		</Reference>
	</ItemGroup>

